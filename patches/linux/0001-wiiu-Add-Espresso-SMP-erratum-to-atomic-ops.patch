diff --git a/arch/powerpc/include/asm/edac.h b/arch/powerpc/include/asm/edac.h
index 5571e23d2..b5808e4a2 100644
--- a/arch/powerpc/include/asm/edac.h
+++ b/arch/powerpc/include/asm/edac.h
@@ -10,6 +10,8 @@
  */
 #ifndef ASM_EDAC_H
 #define ASM_EDAC_H
+#include <asm/asm-espresso.h>
+
 /*
  * ECC atomic, DMA, SMP and interrupt safe scrub function.
  * Implements the per arch edac_atomic_scrub() that EDAC use for software
@@ -27,8 +29,9 @@ static __inline__ void edac_atomic_scrub(void *va, u32 size)
 		 * so we are interrupt, DMA and SMP safe.
 		 */
 		__asm__ __volatile__ ("\n\
-				1:	lwarx	%0,0,%1\n\
-					stwcx.	%0,0,%1\n\
+				1:	lwarx	%0,0,%1\n\"
+					PPCESPRESSO_ERRATA(0,%1)
+				"	stwcx.	%0,0,%1\n\
 					bne-	1b\n\
 					isync"
 					: "=&r"(temp)
diff --git a/arch/powerpc/include/asm/futex.h b/arch/powerpc/include/asm/futex.h
index b3001f8b2..38a55b4f8 100644
--- a/arch/powerpc/include/asm/futex.h
+++ b/arch/powerpc/include/asm/futex.h
@@ -8,13 +8,15 @@
 #include <linux/uaccess.h>
 #include <asm/errno.h>
 #include <asm/synch.h>
+#include <asm/asm-espresso.h>
 
 #define __futex_atomic_op(insn, ret, oldval, uaddr, oparg) \
   __asm__ __volatile ( \
 	PPC_ATOMIC_ENTRY_BARRIER \
 "1:	lwarx	%0,0,%2\n" \
 	insn \
-"2:	stwcx.	%1,0,%2\n" \
+"2:"	PPCESPRESSO_ERRATA(0,%2) \
+	"stwcx.	%1,0,%2\n" \
 	"bne-	1b\n" \
 	PPC_ATOMIC_EXIT_BARRIER \
 	"li	%1,0\n" \
@@ -77,7 +79,8 @@ futex_atomic_cmpxchg_inatomic(u32 *uval, u32 __user *uaddr,
 "1:     lwarx   %1,0,%3         # futex_atomic_cmpxchg_inatomic\n\
         cmpw    0,%1,%4\n\
         bne-    3f\n"
-"2:     stwcx.  %5,0,%3\n\
+"2:"	PPCESPRESSO_ERRATA(0,%3)
+"       stwcx.  %5,0,%3\n\
         bne-    1b\n"
         PPC_ATOMIC_EXIT_BARRIER
 "3:	.section .fixup,\"ax\"\n\
