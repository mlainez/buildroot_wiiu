sdhci-of-hlwd: force PIO on the Wii U wifi controller

The Wii U's Latte SoC has two SDHCI controllers sharing the
"nintendo,hollywood-sdhci" IP: the SD card at 0x0d070000 and the on-board
Broadcom BCM43362 SDIO wifi at 0x0d080000. The wifi controller's SDMA engine
corrupts bulk data transfers -- the brcmfmac firmware-download read-back
collapses to a single 32-bit word followed by zeros, so brcmf_sdio_verifymemory
fails and wifi never comes up. The SD-card controller works correctly with DMA.

Force PIO on the wifi controller only (matched by its register base), leaving
the SD card on DMA.

--- a/drivers/mmc/host/sdhci-of-hlwd.c
+++ b/drivers/mmc/host/sdhci-of-hlwd.c
@@ -68,7 +68,32 @@

 static int sdhci_hlwd_probe(struct platform_device *pdev)
 {
-	return sdhci_pltfm_init_and_add_host(pdev, &sdhci_hlwd_pdata, 0);
+	struct sdhci_host *host;
+	struct resource *iomem;
+	int ret;
+
+	host = sdhci_pltfm_init(pdev, &sdhci_hlwd_pdata, 0);
+	if (IS_ERR(host))
+		return PTR_ERR(host);
+
+	sdhci_get_property(pdev);
+
+	/*
+	 * The Latte's second SDHCI controller (0x0d080000) drives the on-board
+	 * Broadcom BCM43362 SDIO Wi-Fi. Its SDMA engine corrupts bulk data
+	 * transfers (the firmware-download read-back collapses to a single
+	 * word followed by zeros), so force PIO for that controller. The
+	 * SD-card controller (0x0d070000) works correctly with DMA.
+	 */
+	iomem = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (iomem && iomem->start == 0x0d080000)
+		host->quirks |= SDHCI_QUIRK_BROKEN_DMA | SDHCI_QUIRK_BROKEN_ADMA;
+
+	ret = sdhci_add_host(host);
+	if (ret)
+		sdhci_pltfm_free(pdev);
+
+	return ret;
 }

 static const struct of_device_id sdhci_hlwd_of_match[] = {
