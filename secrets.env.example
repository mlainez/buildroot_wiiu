# Copy this to secrets.env, then paste the Starbuck key and IV below.
#
# These two values are the same on every retail Wii U, so one pair works for
# everyone — get them from the linux-loader README. Each is 32 hex characters.
# To read them from your own console, dump its OTP with Dumpling
# (https://github.com/emiyl/dumpling) and extract offsets 0x100 / 0x110:
#
#     xxd -s 0x100 -l 16 -c 16 -p otp.bin    # STARBUCK_KEY (starts B5...)
#     xxd -s 0x110 -l 16 -c 16 -p otp.bin    # STARBUCK_IV  (starts 91...)
#
# DO NOT COMMIT THIS FILE WITH REAL VALUES. .gitignore excludes secrets.env.

STARBUCK_KEY=B5XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STARBUCK_IV=91XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
